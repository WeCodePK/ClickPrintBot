# ClickPrint backend base URL
BACKEND_URL=http://backend:3000

# Shared secret used to mint per-user backend auth tokens
# (sent as `Authorization: ApiKey <SERVICE_KEY>` to POST /api/auth/token)
SERVICE_KEY=

# --- WhatsApp Cloud API -------------------------------------------------------

# Arbitrary string you choose yourself; must match what you enter in the
# Meta App Dashboard's webhook subscription (used only for the one-time
# GET verification handshake).
VERIFY_TOKEN=

# Meta App Secret (App Dashboard -> Settings -> Basic). Used to verify the
# X-Hub-Signature-256 header on every incoming webhook POST.
APP_SECRET=

# Permanent (or long-lived) access token for the WhatsApp Business app,
# used to authenticate outbound Graph API requests.
ACCESS_TOKEN=

# The phone number id (not the phone number itself) to send messages from.
WABA_PHONE_NUMBER_ID=

# Optional: Graph API version/base URL. Override GRAPH_API_BASE_URL in tests
# to point the WhatsApp client at a local stub.
GRAPH_API_VERSION=v21.0
GRAPH_API_BASE_URL=https://graph.facebook.com

# Optional: port the webhook server listens on. Defaults to 3000.
PORT=3000
