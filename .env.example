# ClickPrint backend base URL
# dev:  http://localhost:3000
# prod: https://clickprintbackend.wckd.pk
CLICKPRINT_API_URL=https://clickprintbackend.wckd.pk

# Redis connection (used to cache per-user JWTs and active-draft state)
REDIS_URL=redis://127.0.0.1:6379

# Optional: how long to cache a user's forever-token in redis (seconds).
# Defaults to 30 days. The backend token is a "forever" token, so this is
# just a safety-net refresh interval.
TOKEN_TTL_SECONDS=2592000

# Optional: whatsapp-web.js LocalAuth session id (lets you run multiple bots)
WWEBJS_CLIENT_ID=clickprint

# Optional: directory where the WhatsApp session is persisted.
# Leave blank for local runs (uses ./.wwebjs_auth). In Docker this is set to
# /data (a mounted volume) by docker-compose.
WWEBJS_DATA_PATH=

# Optional: log level (debug | info | warn | error)
LOG_LEVEL=info
